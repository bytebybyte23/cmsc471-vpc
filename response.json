{"statusCode": 200, "body": "<!DOCTYPE html>\r\n\r\n<html class=\"light\" lang=\"en\"><head>\r\n<meta charset=\"utf-8\"/>\r\n<meta content=\"width=device-width, initial-scale=1.0\" name=\"viewport\"/>\r\n<title>Candy — Hello World</title>\r\n<script src=\"https://cdn.tailwindcss.com?plugins=forms,container-queries\"></script>\r\n<link href=\"https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,100..1000;1,9..40,100..1000&amp;display=swap\" rel=\"stylesheet\"/>\r\n<link href=\"https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap\" rel=\"stylesheet\"/>\r\n<link href=\"https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap\" rel=\"stylesheet\"/>\r\n<script id=\"tailwind-config\">\r\n        tailwind.config = {\r\n            darkMode: \"class\",\r\n            theme: {\r\n                extend: {\r\n                    \"colors\": {\r\n                        \"surface-container-lowest\": \"#ffffff\",\r\n                        \"surface-tint\": \"#e040a0\",\r\n                        \"secondary-fixed\": \"#eedcff\",\r\n                        \"secondary-container\": \"#eedcff\",\r\n                        \"primary\": \"#e040a0\",\r\n                        \"error\": \"#e53e3e\",\r\n                        \"tertiary-fixed-dim\": \"#80d0f0\",\r\n                        \"on-tertiary-fixed-variant\": \"#005580\",\r\n                        \"surface-container-highest\": \"#ece2ec\",\r\n                        \"on-surface\": \"#2e1a28\",\r\n                        \"on-background\": \"#2e1a28\",\r\n                        \"on-tertiary\": \"#ffffff\",\r\n                        \"surface\": \"#fef7ff\",\r\n                        \"on-primary\": \"#ffffff\",\r\n                        \"inverse-primary\": \"#f0a0cc\",\r\n                        \"inverse-on-surface\": \"#fef7ff\",\r\n                        \"tertiary-fixed\": \"#c8eaff\",\