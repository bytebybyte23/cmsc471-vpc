vey a sense of high-end digital craftsmanship.\" src=\"https://lh3.googleusercontent.com/aida-public/AB6AXuDFi08N0uv-uOS6frKXO0MRe3lpaiw6HoV-QVaDy8ySii_JJP30FK4vfSZbK96hDYlL_woRfENVMw0PY-hlqYxaKFYbARVRbrNHvhRYf-MMx5QxaWr3oGnEb4xT2vryhrvMj-U6Iy_n41Juhj2yTAQ0fp18zRDfix1fSHu9DRY35tFhQspupjg7jBbZpTb9zhZkP9BE6spR5ZdmhjRr0LBj53_uIlzD4_nmR-8jlx8hbV5mFd49K4Ss-7ClD_8ELYMIkRbyjVfQ9WPm\"/>\r\n</div>\r\n</div>\r\n<!-- Stats Section -->\r\n<div class=\"grid grid-cols-1 md:grid-cols-3 gap-8 mt-20\">\r\n<div class=\"bg-surface-container-low rounded-lg p-6 flex flex-col items-center justify-center shadow-[0_10px_30px_rgba(0,150,204,0.08)] border border-tertiary/10 bouncy-hover\">\r\n<span class=\"material-symbols-outlined text-tertiary text-4xl mb-3\" data-icon=\"speed\">speed</span>\r\n<div class=\"text-3xl font-black text-on-surface tracking-tight\">99.9%</div>\r\n<div class=\"text-sm font-bold text-tertiary uppercase tracking-widest mt-1\">Uptime</div>\r\n</div>\r\n<div class=\"bg-surface-container-low rounded-lg p-6 flex flex-col items-center justify-center shadow-[0_10px_30px_rgba(224,64,160,0.08)] border border-primary/10 bouncy-hover\">\r\n<span class=\"material-symbols-outlined text-primary text-4xl mb-3\" data-icon=\"support_agent\">support_agent</span>\r\n<div class=\"text-3xl font-black text-on-surface tracking-tight\">24/7</div>\r\n<div class=\"text-sm font-bold text-primary uppercase tracking-widest mt-1\">Support</div>\r\n</div>\r\n<div class=\"bg-surface-container-low rounded-lg p-6 flex flex-col items-center justify-center shadow-[0_10px_30px_rgba(124,82,170,0.08)] border border-secondary/10 bouncy-hover\">\r\n<span class=\"material-symbols-outlined text-secondary text-4xl mb-3\" data-icon=\"dashboard_customize\">dashboard_customize</span>\r\n<div class=\"text-3xl font-black text-on-surface tracking-tight\">100+</div>\r\n<div class=\"text-sm font-bold text-secondary uppercase tracking-widest mt-1\">Templates</div>\r\n</div>\r\n</div>\r\n</div>\r\n</section>\r\n</mai